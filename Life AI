<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>LifeAI - AI Life Assistant</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
</head>
<body class="bg-gray-50 dark:bg-gray-950 min-h-screen">
    <div id="login-screen" class="max-w-md mx-auto p-6 pt-20">
        <div class="text-center mb-10">
            <i class="fas fa-brain text-6xl text-emerald-600"></i>
            <h1 class="text-4xl font-bold mt-4">LifeAI</h1>
            <p class="text-gray-600">Global AI Life Assistant</p>
        </div>
        <div class="bg-white dark:bg-gray-800 p-8 rounded-3xl shadow">
            <h2 class="text-2xl font-semibold mb-6 text-center">Sign In</h2>
            <input id="username" type="text" placeholder="Username" class="w-full p-4 rounded-2xl border mb-4">
            <input id="password" type="password" placeholder="Password" class="w-full p-4 rounded-2xl border mb-6">
            <button onclick="login()" class="w-full py-4 bg-emerald-600 text-white rounded-3xl font-medium">Sign In / Register</button>
            <p class="text-center text-sm text-gray-500 mt-4">New user? Just enter any username & password</p>
        </div>
    </div>

    <div id="app-screen" class="hidden">
        <!-- Your full app will go here -->
        <div class="max-w-2xl mx-auto p-4">
            <header class="bg-emerald-700 p-6 rounded-3xl text-white mb-6">
                <div class="flex justify-between items-center">
                    <div class="flex items-center gap-3">
                        <i class="fas fa-brain text-4xl"></i>
                        <div>
                            <h1 class="text-3xl font-bold">LifeAI</h1>
                            <p class="text-emerald-100">Global AI Life Assistant</p>
                        </div>
                    </div>
                    <button onclick="logout()" class="text-sm bg-white/20 px-4 py-2 rounded-full">Logout</button>
                </div>
            </header>
            <!-- Rest of your app content -->
            <div id="main-content"></div>
        </div>
    </div>

    <script>
        function login() {
            const user = document.getElementById('username').value || "User";
            localStorage.setItem('lifeai_user', user);
            document.getElementById('login-screen').classList.add('hidden');
            document.getElementById('app-screen').classList.remove('hidden');
            loadApp();
        }

        function logout() {
            if(confirm("Logout?")) {
                document.getElementById('app-screen').classList.add('hidden');
                document.getElementById('login-screen').classList.remove('hidden');
            }
        }

        function loadApp() {
            // Paste your full app JavaScript and HTML content here
            document.getElementById('main-content').innerHTML = `<p class="text-center text-xl mt-10">Welcome back, ${localStorage.getItem('lifeai_user')}!</p>`;
            // Add the rest of your app here later
        }

        // Auto login if already logged in
        if (localStorage.getItem('lifeai_user')) {
            document.getElementById('login-screen').classList.add('hidden');
            document.getElementById('app-screen').classList.remove('hidden');
            loadApp();
        }
    </script>
</body>
</html>
